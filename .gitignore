# =====================================================================
# BLOCK: GIT IGNORE RULES (.gitignore)
# ---------------------------------------------------------------------
# Files matching these patterns are never uploaded to GitHub.
# NOTE: files that were ALREADY committed before a rule was added stay
# in the repository — the rule only stops NEW files. The CVs in data/
# are still tracked for that reason (see the review notes).
# =====================================================================

# Secrets and generated exports (may contain personal data)
.env
# AI provider API keys and usage counters — must never reach GitHub
ai_providers.json
*.zip
*.xlsx
*.csv

# Local CV files — personal data must not be uploaded
data/

# Python temporary files
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/

# Virtual environments
venv/
env/
